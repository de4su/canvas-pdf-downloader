{
  "manifest_version": 3,
  "name": "Canvas PDF Downloader",
  "version": "1.0.0",
  "description": "Scans Canvas modules for PDFs and live sessions, then downloads PDFs.",
  "permissions": ["downloads", "storage", "tabs"],
  "host_permissions": ["https://*/*", "http://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Canvas PDF Downloader",
    "default_popup": "popup.html"
  }
}
